# Copy this file to `.env` and fill in your own keys. `.env` is gitignored;
# `.env.example` is committed as a template.

# Required for the hutch-skill LLM eval when running with provider=openai.
OPENAI_API_KEY=

# Required for the hutch-skill LLM eval and the LLM-assisted importer
# when running with provider=anthropic.
ANTHROPIC_API_KEY=

# Optional daemon bearer token for SDK/API clients. Do not treat this as a
# browser secret when exposed via NEXT_PUBLIC_HUTCH_TOKEN.
HUTCH_TOKEN=
