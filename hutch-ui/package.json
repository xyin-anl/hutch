{
  "name": "hutch-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Hutch dashboard - Next.js 15 + TypeScript + Tailwind",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev -p 7700",
    "build": "next build",
    "build:daemon": "next build && rm -rf ../hutch-py/src/hutch/ui_server/static && cp -R out ../hutch-py/src/hutch/ui_server/static",
    "start": "next start -p 7700",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.7.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.14"
    }
  }
}
